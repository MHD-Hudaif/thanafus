# Application
APP_NAME="Kauzariyya Musabaqa"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_BASE_URL=/kauzariyya-musabaqa

# Database - Main Dashboard
DB_HOST=127.0.0.1
DB_DATABASE=kauzariyya
DB_USERNAME=root
DB_PASSWORD=

# Database - Musabaqa
MUSABAQA_DB_HOST=127.0.0.1
MUSABAQA_DB_DATABASE=kauzariyya_musabaqa
MUSABAQA_DB_USERNAME=root
MUSABAQA_DB_PASSWORD=

# Session
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAMESITE=Lax

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Security
CSRF_TOKEN_LENGTH=32
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW=60